# DreamVault — Environment Variables
# Copy this file to .env and fill in your Supabase project credentials.
# In Vercel: add these in Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Admin Override Key — allows admin to decrypt any user's diary without their password.
# Keep this secret! Used to wrap a copy of each user's master key during diary lock setup.
